# Frontend deployment profile
VITE_DEPLOYMENT_PROFILE=client-only
VITE_PRIVATE_SYNC_ENABLED=false
VITE_API_BASE_PATH=/api
VITE_FX_REFRESH_ENABLED=true
VITE_FX_REFRESH_RETRIES=2
VITE_FX_REFRESH_RETRY_DELAY_MS=450

# Private sync API hardening
ALLOWED_ORIGINS=https://your-private-host.example

# Deploy script
SSB_REMOTE_HOST=admin@example-host
SSB_REMOTE_PATH=/srv/docker/ssb
